{
  "application": {
    "name": "PredixAI Platform",
    "version": "0.1.0-foundation",
    "mode": "Observador",
    "environment": "development"
  },
  "v1_scope": {
    "market": "Fixed Time",
    "strategy": "Rebote Triplo",
    "capture_interval_seconds": 10,
    "broker": "Olymp Trade",
    "ai_provider": "Gemini",
    "execution_enabled": false,
    "clicks_enabled": false,
    "real_account_enabled": false
  },
  "paths": {
    "root": ".",
    "config": "config",
    "screen_profiles": "config/screen_profiles",
    "data": "data",
    "logs": "logs",
    "captures": "captures",
    "assets": "assets"
  },
  "logging": {
    "level": "INFO",
    "technical_log_file": "predixai.log"
  },
  "perception": {
    "enabled": true,
    "log_on_startup": true
  },
  "window_detection": {
    "enabled": true,
    "max_windows": 100,
    "include_untitled": false,
    "detect_broker": false
  },
  "screen_profile": {
    "default_profile": "config/screen_profiles/default_screen_profile.json",
    "coordinates_enabled": false
  },
  "capture": {
    "enabled": true,
    "output_directory": "captures",
    "image_format": "png",
    "compression": 6,
    "max_history": 100
  },
  "vision": {
    "enabled": true,
    "image_loader": {
      "enabled": true
    },
    "roi": {
      "enabled": true
    }
  },
  "ocr": {
    "enabled": true,
    "provider": "tesseract",
    "language": "por",
    "text_extraction_enabled": false
  },
  "modules": {
    "v1": [
      {
        "name": "Core",
        "package": "predixai.core"
      },
      {
        "name": "Security",
        "package": "predixai.security"
      },
      {
        "name": "Vision",
        "package": "predixai.vision"
      },
      {
        "name": "Auditor",
        "package": "predixai.auditor"
      },
      {
        "name": "Strategy",
        "package": "predixai.strategy"
      },
      {
        "name": "AI Provider",
        "package": "predixai.ai_provider"
      },
      {
        "name": "Dashboard",
        "package": "predixai.dashboard"
      },
      {
        "name": "Broker Adapter",
        "package": "predixai.broker_adapter"
      },
      {
        "name": "Trader",
        "package": "predixai.trader"
      }
    ],
    "future": [
      {
        "name": "Learning",
        "package": "predixai.learning"
      }
    ],
    "support": [
      {
        "name": "Utils",
        "package": "predixai.utils"
      }
    ]
  }
}
