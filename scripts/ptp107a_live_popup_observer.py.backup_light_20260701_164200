from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
import threading
import time
from collections import deque
from pathlib import Path
import tkinter as tk
from tkinter import ttk


BAD_VALUES = {"", "-", "UNKNOWN", "NONE", "NULL", "N/A", "DATA"}
KNOWN_ASSETS = ["Cafeina Index", "Cafeína Index", "LATAM Index"]


def project_root() -> Path:
    return Path(__file__).resolve().parents[1]


def runtime_dir() -> Path:
    return project_root() / "data" / "runtime"


def read_json(path: Path, fallback=None):
    if fallback is None:
        fallback = {}
    try:
        if not path.exists():
            return fallback
        text = path.read_text(encoding="utf-8").strip()
        if not text:
            return fallback
        return json.loads(text)
    except Exception:
        return fallback


def clean(value) -> str:
    if value is None:
        return ""
    return str(value).strip()


def is_bad(value) -> bool:
    return clean(value).upper() in BAD_VALUES


def find_key(obj, keys: set[str]):
    if isinstance(obj, dict):
        for key, value in obj.items():
            if str(key).lower() in keys and not is_bad(value):
                return value

        for value in obj.values():
            found = find_key(value, keys)
            if not is_bad(found):
                return found

    if isinstance(obj, list):
        for item in reversed(obj):
            found = find_key(item, keys)
            if not is_bad(found):
                return found

    return ""


def latest_entry(obj):
    if isinstance(obj, list):
        return obj[-1] if obj else {}

    if isinstance(obj, dict):
        for key in ["readings", "history", "data", "items", "entries"]:
            value = obj.get(key)
            if isinstance(value, list) and value:
                return value[-1]
        return obj

    return {}


def get_active_broker_title() -> str:
    command = (
        "Get-Process chrome,msedge -ErrorAction SilentlyContinue | "
        "Where-Object { $_.MainWindowTitle -match 'Olymp|Index|Cafeina|Cafeína|LATAM|platform|Plataforma' } | "
        "Select-Object -First 1 -ExpandProperty MainWindowTitle"
    )

    for exe in ["powershell.exe", "powershell"]:
        try:
            result = subprocess.run(
                [exe, "-NoProfile", "-Command", command],
                capture_output=True,
                text=True,
                timeout=5,
            )
            title = clean(result.stdout)
            if title:
                return title.splitlines()[0]
        except Exception:
            pass

    return ""


def extract_asset_from_title(title: str) -> str:
    title = clean(title)

    for asset in KNOWN_ASSETS:
        if asset.lower() in title.lower():
            return asset.replace("Cafeína", "Cafeina")

    match = re.search(
        r"([A-Za-zÀ-ÿ0-9]+(?:\s+[A-Za-zÀ-ÿ0-9]+){0,3}\s+Index)",
        title,
        re.IGNORECASE,
    )

    if match:
        return match.group(1).strip().replace("Cafeína", "Cafeina")

    return "UNKNOWN"


def extract_price_from_title(title: str) -> str:
    title = clean(title)
    match = re.search(r"\b(\d{3,6}[.,]\d{1,4})\b", title)

    if match:
        return match.group(1)

    return ""


def normalize_asset(asset: str, title: str) -> str:
    if is_bad(asset):
        return extract_asset_from_title(title)
    return clean(asset)


def to_float(value):
    try:
        text = clean(value).replace(",", ".")
        text = re.sub(r"[^0-9.\-]", "", text)
        return float(text)
    except Exception:
        return None


def find_latest_runtime_json():
    folder = runtime_dir()

    if not folder.exists():
        return None

    files = [path for path in folder.rglob("*.json") if path.is_file()]

    if not files:
        return None

    return max(files, key=lambda path: path.stat().st_mtime_ns)


class LivePopup:
    def __init__(self, cycles: int, interval: int, clear_runtime: bool):
        self.cycles = cycles
        self.interval = interval
        self.status = "INICIANDO"
        self.logs = deque(maxlen=6)
        self.process = None
        self.last_seen_mtime = None
        self.new_reads = 0
        self.prices = deque(maxlen=40)

        if clear_runtime:
            self.clear_runtime_files()

        self.root = tk.Tk()
        self.root.title("PredixAI Live")
        self.root.geometry("390x430+40+90")
        self.root.attributes("-topmost", True)
        self.root.resizable(False, False)
        self.root.protocol("WM_DELETE_WINDOW", self.close)

        self.vars = {
            "status": tk.StringVar(value="-"),
            "count": tk.StringVar(value="0/0"),
            "asset": tk.StringVar(value="-"),
            "price": tk.StringVar(value="-"),
            "balance": tk.StringVar(value="-"),
            "payout": tk.StringVar(value="-"),
            "timeframe": tk.StringVar(value="-"),
            "valid": tk.StringVar(value="-"),
            "reason": tk.StringVar(value="-"),
            "file": tk.StringVar(value="-"),
        }

        self.build_ui()

        threading.Thread(target=self.run_live_loop, daemon=True).start()
        self.root.after(700, self.refresh)

    def clear_runtime_files(self):
        folder = runtime_dir()
        folder.mkdir(parents=True, exist_ok=True)

        for name in [
            "last_live_reading.json",
            "live_price_history.json",
            "live_timing_profile.json",
        ]:
            path = folder / name
            if path.exists():
                path.unlink()

    def build_ui(self):
        main = ttk.Frame(self.root, padding=10)
        main.pack(fill="both", expand=True)

        ttk.Label(main, text="PREDIXAI LIVE", font=("Arial", 14, "bold")).pack(anchor="w")

        for label, key in [
            ("Status", "status"),
            ("Leituras", "count"),
            ("Ativo", "asset"),
            ("Preço", "price"),
            ("Saldo", "balance"),
            ("Payout", "payout"),
            ("Tempo", "timeframe"),
            ("Válido", "valid"),
            ("Motivo", "reason"),
            ("Arquivo", "file"),
        ]:
            row = ttk.Frame(main)
            row.pack(fill="x", pady=1)
            ttk.Label(row, text=f"{label}:", width=8, font=("Arial", 9, "bold")).pack(side="left")
            ttk.Label(row, textvariable=self.vars[key], wraplength=285).pack(side="left")

        self.canvas = tk.Canvas(main, width=360, height=75, bg="white")
        self.canvas.pack(pady=(8, 6))

        ttk.Label(main, text="Log:", font=("Arial", 9, "bold")).pack(anchor="w")
        self.log_box = tk.Text(main, height=5, wrap="word")
        self.log_box.pack(fill="x")

        ttk.Label(
            main,
            text="Seguro: sem clique, sem compra, sem venda.",
            font=("Arial", 8, "italic"),
        ).pack(anchor="w", pady=(4, 0))

    def log(self, text):
        text = clean(text)
        if text:
            self.logs.append(text)

    def cli_help(self) -> str:
        try:
            result = subprocess.run(
                [sys.executable, "-m", "predixai.main", "--help"],
                cwd=str(project_root()),
                capture_output=True,
                text=True,
                timeout=15,
            )
            return (result.stdout or "") + "\n" + (result.stderr or "")
        except Exception:
            return ""

    def build_command(self):
        help_text = self.cli_help()

        command = [sys.executable, "-m", "predixai.main", "--live-loop"]

        if "--loop-count" in help_text:
            command += ["--loop-count", str(self.cycles)]

        if "--loop-interval" in help_text:
            command += ["--loop-interval", str(self.interval)]

        return command

    def run_live_loop(self):
        command = self.build_command()
        self.status = "COLETANDO"
        self.log("Rodando live-loop...")

        try:
            self.process = subprocess.Popen(
                command,
                cwd=str(project_root()),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )

            if self.process.stdout:
                for line in self.process.stdout:
                    if "Live loop reading" in line or "PredixAI command failed" in line:
                        self.log(line)

            code = self.process.wait()

            if code == 0:
                self.status = "FINALIZADO"
            else:
                self.status = f"ERRO {code}"

        except Exception as exc:
            self.status = "ERRO"
            self.log(str(exc))

    def read_runtime_state(self):
        last_path = runtime_dir() / "last_live_reading.json"
        timing_path = runtime_dir() / "live_timing_profile.json"
        history_path = runtime_dir() / "live_price_history.json"

        last_data = read_json(last_path, {})
        timing_data = read_json(timing_path, [])
        history_data = read_json(history_path, [])

        timing_entry = latest_entry(timing_data)
        latest_path = find_latest_runtime_json()
        latest_data = read_json(latest_path, {}) if latest_path else {}

        latest_entry_data = latest_entry(latest_data)

        candidates = [
            latest_entry_data,
            timing_entry,
            last_data,
        ]

        merged = {}

        for candidate in reversed(candidates):
            if isinstance(candidate, dict):
                merged.update(candidate)

        title = (
            find_key(merged, {"window_title", "title"})
            or find_key(last_data, {"window_title", "title"})
            or get_active_broker_title()
        )

        asset = (
            find_key(merged, {"asset", "symbol", "instrument"})
            or find_key(last_data, {"asset", "symbol", "instrument"})
        )
        asset = normalize_asset(asset, title)

        price = (
            find_key(merged, {"price", "price_value", "current_price", "last_price"})
            or extract_price_from_title(title)
        )

        balance = find_key(merged, {"balance", "account_balance"})
        payout = find_key(merged, {"payout"})
        timeframe = find_key(merged, {"timeframe", "tf"})
        valid = find_key(merged, {"valid_runtime_reading", "valid", "is_valid"})
        reason = find_key(merged, {"rejection_reasons", "rejection_reason", "reason"})

        if isinstance(reason, list):
            reason = ", ".join(str(item) for item in reason)

        price_value = to_float(price)
        if price_value is not None:
            self.prices.append(price_value)

        if latest_path:
            try:
                mtime = latest_path.stat().st_mtime_ns
                if mtime != self.last_seen_mtime:
                    self.last_seen_mtime = mtime
                    self.new_reads += 1
            except Exception:
                pass

        return {
            "asset": asset,
            "price": price,
            "balance": balance,
            "payout": payout,
            "timeframe": timeframe,
            "valid": valid,
            "reason": reason,
            "file": latest_path.name if latest_path else "aguardando JSON",
        }

    def refresh(self):
        state = self.read_runtime_state()

        self.vars["status"].set(self.status)
        self.vars["count"].set(f"{self.new_reads}/{self.cycles}")
        self.vars["asset"].set(clean(state["asset"]) or "-")
        self.vars["price"].set(clean(state["price"]) or "-")
        self.vars["balance"].set(clean(state["balance"]) or "-")
        self.vars["payout"].set(clean(state["payout"]) or "-")
        self.vars["timeframe"].set(clean(state["timeframe"]) or "-")
        self.vars["valid"].set(clean(state["valid"]) or "-")
        self.vars["reason"].set(clean(state["reason"]) or "-")
        self.vars["file"].set(clean(state["file"]) or "-")

        self.draw_chart()
        self.log_box.delete("1.0", "end")
        self.log_box.insert("1.0", "\n".join(self.logs))

        self.root.after(700, self.refresh)

    def draw_chart(self):
        self.canvas.delete("all")

        prices = list(self.prices)

        if len(prices) < 2:
            self.canvas.create_text(180, 38, text="Aguardando preços...")
            return

        width = 360
        height = 75
        padding = 8
        low = min(prices)
        high = max(prices)

        if high == low:
            high += 1

        points = []

        for index, price in enumerate(prices):
            x = padding + (index / (len(prices) - 1)) * (width - 2 * padding)
            y = height - padding - ((price - low) / (high - low)) * (height - 2 * padding)
            points.extend([x, y])

        self.canvas.create_line(points, width=2)
        self.canvas.create_text(8, 8, anchor="nw", text=f"{low:.2f} / {high:.2f}")

    def close(self):
        try:
            if self.process and self.process.poll() is None:
                self.process.terminate()
        except Exception:
            pass

        self.root.destroy()

    def run(self):
        self.root.mainloop()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--cycles", type=int, default=60)
    parser.add_argument("--interval", type=int, default=5)
    parser.add_argument("--clear-runtime", action="store_true")
    args = parser.parse_args()

    LivePopup(
        cycles=args.cycles,
        interval=args.interval,
        clear_runtime=args.clear_runtime,
    ).run()


if __name__ == "__main__":
    main()
