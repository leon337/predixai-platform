from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
import threading
import time
from collections import deque
from pathlib import Path
import tkinter as tk
from tkinter import ttk


BAD_ASSETS = {"", "DATA", "UNKNOWN", "NONE", "NULL", "N/A", "-"}
KNOWN_ASSETS = ["Cafeina Index", "Cafeína Index", "LATAM Index"]


def root_dir() -> Path:
    return Path(__file__).resolve().parents[1]


def read_json(path: Path):
    try:
        if not path.exists():
            return {}
        text = path.read_text(encoding="utf-8").strip()
        return json.loads(text) if text else {}
    except Exception:
        return {}


def clean(value) -> str:
    return "" if value is None else str(value).strip()


def latest_file(pattern: str):
    files = list(root_dir().glob(pattern))
    files = [p for p in files if p.is_file()]
    if not files:
        return None
    return max(files, key=lambda p: p.stat().st_mtime)


def find_value(obj, wanted_keys):
    if isinstance(obj, dict):
        for key, value in obj.items():
            if str(key).lower() in wanted_keys:
                return value
        for value in obj.values():
            found = find_value(value, wanted_keys)
            if found not in [None, "", [], {}]:
                return found

    if isinstance(obj, list):
        for item in obj:
            found = find_value(item, wanted_keys)
            if found not in [None, "", [], {}]:
                return found

    return None


def extract_asset_from_title(title: str) -> str:
    title = clean(title)

    for asset in KNOWN_ASSETS:
        if asset.lower() in title.lower():
            return asset.replace("Cafeína", "Cafeina")

    match = re.search(
        r"([A-Za-zÀ-ÿ0-9]+(?:\s+[A-Za-zÀ-ÿ0-9]+){0,3}\s+Index)",
        title,
        re.IGNORECASE,
    )

    if match:
        return match.group(1).replace("Cafeína", "Cafeina").strip()

    return "UNKNOWN"


def normalize_asset(asset, title):
    asset = clean(asset)
    title = clean(title)

    if asset.upper() in BAD_ASSETS or asset.lower() == "data":
        return extract_asset_from_title(title)

    return asset or extract_asset_from_title(title)


def price_to_float(value):
    try:
        text = clean(value).replace(",", ".")
        text = re.sub(r"[^0-9.\-]", "", text)
        return float(text)
    except Exception:
        return None


def extract_prices(obj):
    prices = []

    def walk(x):
        if isinstance(x, dict):
            for key, value in x.items():
                if str(key).lower() in {"price", "value", "last_price"}:
                    price = price_to_float(value)
                    if price is not None:
                        prices.append(price)
                walk(value)

        elif isinstance(x, list):
            for item in x:
                walk(item)

    walk(obj)
    return prices


class Popup:
    def __init__(self, cycles: int, clear_runtime: bool):
        self.cycles = cycles
        self.logs = deque(maxlen=8)
        self.status = "INICIANDO"
        self.read_count = 0
        self.last_mtime = None
        self.last_path = None

        if clear_runtime:
            self.clear_runtime()

        self.root = tk.Tk()
        self.root.title("PredixAI Live")
        self.root.geometry("390x520+30+80")
        self.root.attributes("-topmost", True)
        self.root.resizable(False, False)

        self.vars = {
            "status": tk.StringVar(value="-"),
            "count": tk.StringVar(value="0/0"),
            "asset": tk.StringVar(value="-"),
            "price": tk.StringVar(value="-"),
            "balance": tk.StringVar(value="-"),
            "payout": tk.StringVar(value="-"),
            "timeframe": tk.StringVar(value="-"),
            "time": tk.StringVar(value="-"),
            "file": tk.StringVar(value="-"),
            "prices": tk.StringVar(value="-"),
        }

        self.build_ui()
        threading.Thread(target=self.run_live_loop, daemon=True).start()
        self.root.after(700, self.refresh)

    def clear_runtime(self):
        folder = root_dir() / "data" / "runtime"
        folder.mkdir(parents=True, exist_ok=True)

        for name in ["last_live_reading.json", "live_price_history.json"]:
            path = folder / name
            if path.exists():
                path.unlink()

    def log(self, text):
        text = clean(text)
        if text:
            self.logs.append(text)

    def build_ui(self):
        main = ttk.Frame(self.root, padding=10)
        main.pack(fill="both", expand=True)

        ttk.Label(main, text="PREDIXAI LIVE", font=("Arial", 14, "bold")).pack(anchor="w")

        self.row(main, "Status", "status")
        self.row(main, "Leituras", "count")
        self.row(main, "Ativo", "asset")
        self.row(main, "Preço", "price")
        self.row(main, "Saldo", "balance")
        self.row(main, "Payout", "payout")
        self.row(main, "Tempo", "timeframe")
        self.row(main, "Horário", "time")
        self.row(main, "Arquivo", "file")
        self.row(main, "Últimos", "prices")

        self.canvas = tk.Canvas(main, width=360, height=90, bg="white")
        self.canvas.pack(pady=(8, 8))

        ttk.Label(main, text="Log:", font=("Arial", 9, "bold")).pack(anchor="w")
        self.log_box = tk.Text(main, height=7, wrap="word")
        self.log_box.pack(fill="x")

        ttk.Label(
            main,
            text="Seguro: sem clique, sem compra, sem venda.",
            font=("Arial", 8, "italic"),
        ).pack(anchor="w", pady=(5, 0))

    def row(self, parent, label, key):
        frame = ttk.Frame(parent)
        frame.pack(fill="x", pady=2)

        ttk.Label(frame, text=f"{label}:", width=9, font=("Arial", 9, "bold")).pack(side="left")
        ttk.Label(frame, textvariable=self.vars[key], wraplength=270).pack(side="left")

    def run_live_loop(self):
        cmd = [
            sys.executable,
            "-m",
            "predixai.main",
            "--live-loop",
            "--loop-count",
            str(self.cycles),
        ]

        self.status = "COLETANDO"
        self.log("Rodando: " + " ".join(cmd))

        try:
            process = subprocess.Popen(
                cmd,
                cwd=str(root_dir()),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )

            if process.stdout:
                for line in process.stdout:
                    self.log(line)

            code = process.wait()

            if code == 0:
                self.status = "FINALIZADO"
            else:
                self.status = f"ERRO {code}"

        except Exception as exc:
            self.status = "ERRO AO CAPTURAR"
            self.log(str(exc))

    def get_latest_reading(self):
        path = latest_file("**/last_live_reading.json")

        if not path:
            return {}, None

        try:
            mtime = path.stat().st_mtime_ns
            if mtime != self.last_mtime:
                self.last_mtime = mtime
                self.read_count += 1
        except Exception:
            pass

        self.last_path = path
        return read_json(path), path

    def get_history(self):
        path = latest_file("**/live_price_history.json")
        if not path:
            return []
        return extract_prices(read_json(path))

    def refresh(self):
        reading, path = self.get_latest_reading()
        prices = self.get_history()

        title = find_value(reading, {"window_title", "title"}) or ""
        asset = find_value(reading, {"asset", "symbol", "instrument"})
        asset = normalize_asset(asset, title)

        price = find_value(reading, {"price", "current_price", "last_price"})
        balance = find_value(reading, {"balance", "account_balance"})
        payout = find_value(reading, {"payout"})
        timeframe = find_value(reading, {"timeframe", "tf"})
        timestamp = find_value(reading, {"timestamp", "time", "created_at"})

        self.vars["status"].set(self.status)
        self.vars["count"].set(f"{self.read_count}/{self.cycles}")
        self.vars["asset"].set(asset or "-")
        self.vars["price"].set(clean(price) or "-")
        self.vars["balance"].set(clean(balance) or "-")
        self.vars["payout"].set(clean(payout) or "-")
        self.vars["timeframe"].set(clean(timeframe) or "-")
        self.vars["time"].set(clean(timestamp) or "-")
        self.vars["file"].set(path.name if path else "aguardando JSON")

        if prices:
            self.vars["prices"].set(" | ".join(f"{p:.2f}" for p in prices[-4:]))
        else:
            self.vars["prices"].set("-")

        self.draw_chart(prices[-40:])
        self.log_box.delete("1.0", "end")
        self.log_box.insert("1.0", "\n".join(self.logs))

        self.root.after(700, self.refresh)

    def draw_chart(self, prices):
        self.canvas.delete("all")

        if len(prices) < 2:
            self.canvas.create_text(180, 45, text="Aguardando preços...")
            return

        w, h, p = 360, 90, 8
        low, high = min(prices), max(prices)

        if high == low:
            high += 1

        points = []

        for i, price in enumerate(prices):
            x = p + (i / (len(prices) - 1)) * (w - 2 * p)
            y = h - p - ((price - low) / (high - low)) * (h - 2 * p)
            points.extend([x, y])

        self.canvas.create_line(points, width=2)
        self.canvas.create_text(8, 8, anchor="nw", text=f"{low:.2f} / {high:.2f}")

    def run(self):
        self.root.mainloop()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--cycles", type=int, default=60)
    parser.add_argument("--clear-runtime", action="store_true")
    args = parser.parse_args()

    Popup(cycles=args.cycles, clear_runtime=args.clear_runtime).run()


if __name__ == "__main__":
    main()
