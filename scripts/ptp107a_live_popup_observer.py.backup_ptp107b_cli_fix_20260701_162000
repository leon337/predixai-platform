from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
import threading
import time
from collections import deque
from pathlib import Path
import tkinter as tk
from tkinter import ttk


BAD_ASSETS = {"", "DATA", "UNKNOWN", "NONE", "NULL", "N/A", "-"}
KNOWN_ASSETS = ["Cafeina Index", "Cafeína Index", "LATAM Index"]


def project_root() -> Path:
    return Path(__file__).resolve().parents[1]


def runtime_dir() -> Path:
    return project_root() / "data" / "runtime"


def read_json(path: Path, fallback):
    try:
        if not path.exists():
            return fallback
        text = path.read_text(encoding="utf-8").strip()
        if not text:
            return fallback
        return json.loads(text)
    except Exception:
        return fallback


def clean_text(value) -> str:
    if value is None:
        return ""
    return str(value).strip()


def extract_asset_from_window_title(window_title: str) -> str:
    title = clean_text(window_title)

    for asset in KNOWN_ASSETS:
        if asset.lower() in title.lower():
            return asset.replace("Cafeína", "Cafeina")

    match = re.search(
        r"([A-Za-zÀ-ÿ0-9]+(?:\s+[A-Za-zÀ-ÿ0-9]+){0,3}\s+Index)",
        title,
        flags=re.IGNORECASE,
    )

    if match:
        found = re.sub(r"\s+", " ", match.group(1).strip())
        return found.replace("Cafeína", "Cafeina")

    return "UNKNOWN"


def normalize_asset(reading: dict) -> str:
    asset = clean_text(reading.get("asset"))
    window_title = clean_text(reading.get("window_title"))

    if asset.upper() in BAD_ASSETS or asset.lower() == "data":
        return extract_asset_from_window_title(window_title)

    return asset


def extract_history_points(history_data):
    if isinstance(history_data, list):
        return history_data

    if isinstance(history_data, dict):
        for key in ["history", "points", "readings", "prices", "data"]:
            value = history_data.get(key)
            if isinstance(value, list):
                return value

    return []


def extract_price(point):
    if isinstance(point, dict):
        for key in ["price", "value", "last_price"]:
            value = point.get(key)
            try:
                return float(str(value).replace(",", "."))
            except Exception:
                pass

    try:
        return float(str(point).replace(",", "."))
    except Exception:
        return None


def format_value(value, default="-"):
    value = clean_text(value)
    return value if value else default


class LivePopup:
    def __init__(self, cycles: int, interval: float, no_capture: bool, clear_runtime: bool):
        self.root_dir = project_root()
        self.last_path = runtime_dir() / "last_live_reading.json"
        self.history_path = runtime_dir() / "live_price_history.json"

        self.cycles = cycles
        self.interval = interval
        self.no_capture = no_capture
        self.clear_runtime = clear_runtime

        self.capture_process = None
        self.capture_thread = None
        self.capture_status = "INICIANDO"
        self.logs = deque(maxlen=18)
        self.seen_timestamps = set()
        self.reading_count = 0

        if self.clear_runtime:
            self.clear_runtime_files()

        self.root = tk.Tk()
        self.root.title("PredixAI Trader — Live Popup Observer")
        self.root.geometry("720x780+30+60")
        self.root.attributes("-topmost", True)

        self.vars = {
            "status": tk.StringVar(value="INICIANDO"),
            "cycles": tk.StringVar(value=f"0/{cycles}"),
            "asset": tk.StringVar(value="-"),
            "price": tk.StringVar(value="-"),
            "balance": tk.StringVar(value="-"),
            "payout": tk.StringVar(value="-"),
            "timeframe": tk.StringVar(value="-"),
            "timestamp": tk.StringVar(value="-"),
            "history_count": tk.StringVar(value="0"),
            "last_prices": tk.StringVar(value="-"),
            "window_title": tk.StringVar(value="-"),
        }

        self.build_ui()

        if not self.no_capture:
            self.start_capture_background()
        else:
            self.capture_status = "MODO LEITURA: usando JSON existente"

        self.root.after(500, self.refresh_ui)

    def clear_runtime_files(self):
        runtime_dir().mkdir(parents=True, exist_ok=True)
        for path in [self.last_path, self.history_path]:
            try:
                if path.exists():
                    path.unlink()
            except Exception:
                pass

    def add_log(self, text: str):
        text = clean_text(text)
        if text:
            self.logs.append(text)

    def build_ui(self):
        main = ttk.Frame(self.root, padding=12)
        main.pack(fill="both", expand=True)

        ttk.Label(
            main,
            text="PREDIXAI LIVE POPUP OBSERVER",
            font=("Arial", 14, "bold"),
        ).pack(anchor="w", pady=(0, 10))

        grid = ttk.Frame(main)
        grid.pack(fill="x")

        rows = [
            ("Status", "status"),
            ("Coletas novas", "cycles"),
            ("Ativo", "asset"),
            ("Preço", "price"),
            ("Saldo", "balance"),
            ("Payout", "payout"),
            ("Timeframe", "timeframe"),
            ("Horário", "timestamp"),
            ("Pontos no histórico", "history_count"),
            ("Últimos preços", "last_prices"),
        ]

        for row, (label, key) in enumerate(rows):
            ttk.Label(grid, text=f"{label}:", font=("Arial", 10, "bold")).grid(
                row=row, column=0, sticky="w", pady=3
            )
            ttk.Label(grid, textvariable=self.vars[key], wraplength=500).grid(
                row=row, column=1, sticky="w", pady=3
            )

        ttk.Label(main, text="Mini histórico:", font=("Arial", 10, "bold")).pack(
            anchor="w", pady=(12, 4)
        )

        self.canvas = tk.Canvas(main, width=670, height=130, bg="white")
        self.canvas.pack(fill="x")

        ttk.Label(main, text="Título da janela:", font=("Arial", 10, "bold")).pack(
            anchor="w", pady=(12, 4)
        )

        ttk.Label(
            main,
            textvariable=self.vars["window_title"],
            wraplength=670,
        ).pack(anchor="w")

        ttk.Label(main, text="Log da captura:", font=("Arial", 10, "bold")).pack(
            anchor="w", pady=(12, 4)
        )

        self.log_text = tk.Text(main, height=8, wrap="word")
        self.log_text.pack(fill="both")

        ttk.Label(main, text="Última captura JSON:", font=("Arial", 10, "bold")).pack(
            anchor="w", pady=(12, 4)
        )

        self.raw_text = tk.Text(main, height=9, wrap="word")
        self.raw_text.pack(fill="both", expand=True)

        ttk.Label(
            main,
            text="Modo seguro: sem clique, sem compra, sem venda, sem ordem real.",
            font=("Arial", 9, "italic"),
        ).pack(anchor="w", pady=(8, 0))

    def start_capture_background(self):
        self.capture_thread = threading.Thread(target=self.run_capture_controller, daemon=True)
        self.capture_thread.start()

    def run_capture_controller(self):
        live_loop_commands = [
            [sys.executable, "-m", "predixai.main", "--live-loop", "--cycles", str(self.cycles), "--interval", str(self.interval)],
            [sys.executable, "-m", "predixai.main", "live-loop", "--cycles", str(self.cycles), "--interval", str(self.interval)],
        ]

        for command in live_loop_commands:
            ok = self.try_live_loop(command)
            if ok:
                return

        self.add_log("live-loop não iniciou. Tentando fallback com live-once em repetição.")
        self.run_live_once_fallback()

    def try_live_loop(self, command) -> bool:
        label = " ".join(command)
        self.capture_status = f"TENTANDO: {label}"
        self.add_log(f"TENTANDO: {label}")

        try:
            process = subprocess.Popen(
                command,
                cwd=str(self.root_dir),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )
            self.capture_process = process

            reader = threading.Thread(target=self.read_process_output, args=(process,), daemon=True)
            reader.start()

            time.sleep(4)

            code = process.poll()

            if code is None:
                self.capture_status = "COLETANDO VIA LIVE-LOOP"
                self.add_log("live-loop iniciou com sucesso.")
                process.wait()
                final_code = process.returncode

                if final_code == 0:
                    self.capture_status = "CAPTURA FINALIZADA"
                else:
                    self.capture_status = f"LIVE-LOOP ENCERROU COM ERRO: {final_code}"

                return True

            self.add_log(f"Comando falhou rápido. Código: {code}")
            return False

        except Exception as exc:
            self.add_log(f"ERRO AO INICIAR live-loop: {exc}")
            return False

    def read_process_output(self, process):
        try:
            if process.stdout:
                for line in process.stdout:
                    self.add_log(line)
        except Exception as exc:
            self.add_log(f"ERRO LENDO SAÍDA: {exc}")

    def run_live_once_fallback(self):
        once_commands = [
            [sys.executable, "-m", "predixai.main", "--live-once"],
            [sys.executable, "-m", "predixai.main", "live-once"],
        ]

        success_count = 0

        for index in range(1, self.cycles + 1):
            self.capture_status = f"COLETANDO VIA LIVE-ONCE {index}/{self.cycles}"
            command_worked = False

            for command in once_commands:
                label = " ".join(command)

                try:
                    result = subprocess.run(
                        command,
                        cwd=str(self.root_dir),
                        capture_output=True,
                        text=True,
                        timeout=40,
                    )

                    output = ((result.stdout or "") + "\n" + (result.stderr or "")).strip()

                    if output:
                        for line in output.splitlines()[-4:]:
                            self.add_log(line)

                    if result.returncode == 0:
                        success_count += 1
                        command_worked = True
                        break

                    self.add_log(f"Falhou: {label} | Código {result.returncode}")

                except Exception as exc:
                    self.add_log(f"Erro: {label} | {exc}")

            if not command_worked:
                self.capture_status = "CAPTURA NÃO INICIOU — veja o log"
                self.add_log("Nenhum comando live-once funcionou.")
                return

            time.sleep(self.interval)

        self.capture_status = f"CAPTURA FINALIZADA: {success_count}/{self.cycles}"

    def refresh_ui(self):
        reading = read_json(self.last_path, {})
        history_data = read_json(self.history_path, [])
        history_points = extract_history_points(history_data)

        timestamp = clean_text(reading.get("timestamp") or reading.get("time"))

        if timestamp and timestamp not in self.seen_timestamps:
            self.seen_timestamps.add(timestamp)
            self.reading_count += 1

        asset = normalize_asset(reading)
        prices = [extract_price(point) for point in history_points]
        prices = [price for price in prices if price is not None]

        self.vars["status"].set(self.capture_status)
        self.vars["cycles"].set(f"{self.reading_count}/{self.cycles}")
        self.vars["asset"].set(format_value(asset))
        self.vars["price"].set(format_value(reading.get("price")))
        self.vars["balance"].set(format_value(reading.get("balance")))
        self.vars["payout"].set(format_value(reading.get("payout")))
        self.vars["timeframe"].set(format_value(reading.get("timeframe")))
        self.vars["timestamp"].set(format_value(timestamp))
        self.vars["history_count"].set(str(len(history_points)))
        self.vars["window_title"].set(format_value(reading.get("window_title")))

        if prices:
            self.vars["last_prices"].set(" | ".join(f"{p:.2f}" for p in prices[-5:]))
        else:
            self.vars["last_prices"].set("-")

        self.draw_chart(prices[-60:])
        self.update_text_boxes(reading)

        self.root.after(1000, self.refresh_ui)

    def draw_chart(self, prices):
        self.canvas.delete("all")

        width = 670
        height = 130
        padding = 12

        if len(prices) < 2:
            self.canvas.create_text(width / 2, height / 2, text="Aguardando histórico novo...")
            return

        min_price = min(prices)
        max_price = max(prices)

        if max_price == min_price:
            max_price += 1

        points = []

        for index, price in enumerate(prices):
            x = padding + (index / (len(prices) - 1)) * (width - 2 * padding)
            y = height - padding - ((price - min_price) / (max_price - min_price)) * (height - 2 * padding)
            points.extend([x, y])

        self.canvas.create_line(points, width=2)
        self.canvas.create_text(
            10,
            10,
            anchor="nw",
            text=f"Min {min_price:.2f} | Max {max_price:.2f}",
        )

    def update_text_boxes(self, reading):
        self.log_text.delete("1.0", "end")
        self.log_text.insert("1.0", "\n".join(self.logs))

        try:
            content = json.dumps(reading, ensure_ascii=False, indent=2)
        except Exception:
            content = str(reading)

        self.raw_text.delete("1.0", "end")
        self.raw_text.insert("1.0", content)

    def run(self):
        self.root.mainloop()


def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument("--cycles", type=int, default=60)
    parser.add_argument("--interval", type=float, default=5)
    parser.add_argument("--no-capture", action="store_true")
    parser.add_argument("--clear-runtime", action="store_true")
    return parser.parse_args()


def main():
    args = parse_args()
    app = LivePopup(
        cycles=args.cycles,
        interval=args.interval,
        no_capture=args.no_capture,
        clear_runtime=args.clear_runtime,
    )
    app.run()


if __name__ == "__main__":
    main()
