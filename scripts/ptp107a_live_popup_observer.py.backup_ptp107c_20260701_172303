from __future__ import annotations

import argparse
import ctypes
import json
import re
import subprocess
import sys
import threading
from collections import deque
from pathlib import Path
import tkinter as tk
from tkinter import ttk


BAD = {"", "-", "UNKNOWN", "NONE", "NULL", "N/A", "DATA"}
KNOWN_ASSETS = ["Cafeina Index", "Cafeína Index", "LATAM Index"]


def project_root() -> Path:
    return Path(__file__).resolve().parents[1]


def runtime_dir() -> Path:
    return project_root() / "data" / "runtime"


def read_json(path: Path, fallback):
    try:
        if not path.exists():
            return fallback
        text = path.read_text(encoding="utf-8").strip()
        return json.loads(text) if text else fallback
    except Exception:
        return fallback


def clean(value) -> str:
    return "" if value is None else str(value).strip()


def is_good(value) -> bool:
    return clean(value).upper() not in BAD


def latest_item(value):
    if isinstance(value, list):
        return value[-1] if value else {}
    if isinstance(value, dict):
        return value
    return {}


def pick(*values):
    for value in values:
        if is_good(value):
            return value
    return ""


def find_value(obj, keys: set[str]):
    if isinstance(obj, dict):
        for key, value in obj.items():
            if str(key).lower() in keys and is_good(value):
                return value

    return ""


def get_window_titles() -> list[str]:
    titles = []

    try:
        user32 = ctypes.windll.user32

        enum_proc = ctypes.WINFUNCTYPE(ctypes.c_bool, ctypes.c_void_p, ctypes.c_void_p)

        def callback(hwnd, _):
            if not user32.IsWindowVisible(hwnd):
                return True

            length = user32.GetWindowTextLengthW(hwnd)

            if length <= 0:
                return True

            buffer = ctypes.create_unicode_buffer(length + 1)
            user32.GetWindowTextW(hwnd, buffer, length + 1)
            title = clean(buffer.value)

            if title:
                lower = title.lower()
                tokens = ["olymp", "cafeina", "cafeína", "latam", "index", "plataforma"]
                if any(token in lower for token in tokens):
                    titles.append(title)

            return True

        user32.EnumWindows(enum_proc(callback), 0)

    except Exception:
        return []

    def score(title: str) -> int:
        lower = title.lower()
        value = 0
        if "cafeina" in lower or "cafeína" in lower:
            value += 10
        if "index" in lower:
            value += 5
        if re.search(r"\d{3,6}[.,]\d+", title):
            value += 5
        return value

    return sorted(titles, key=score, reverse=True)


def get_broker_title() -> str:
    titles = get_window_titles()
    return titles[0] if titles else ""


def asset_from_title(title: str) -> str:
    for asset in KNOWN_ASSETS:
        if asset.lower() in title.lower():
            return asset.replace("Cafeína", "Cafeina")

    match = re.search(
        r"([A-Za-zÀ-ÿ0-9]+(?:\s+[A-Za-zÀ-ÿ0-9]+){0,3}\s+Index)",
        title,
        re.IGNORECASE,
    )

    if match:
        return match.group(1).replace("Cafeína", "Cafeina").strip()

    return "UNKNOWN"


def price_from_title(title: str) -> str:
    match = re.search(r"\b(\d{3,6}[.,]\d{1,5})\b", title)
    return match.group(1) if match else ""


def to_float(value):
    try:
        text = clean(value).replace(",", ".")
        text = re.sub(r"[^0-9.\-]", "", text)
        return float(text)
    except Exception:
        return None


class Popup:
    def __init__(self, cycles: int, interval: int, clear_runtime: bool, no_capture: bool):
        self.cycles = cycles
        self.interval = interval
        self.no_capture = no_capture
        self.process = None
        self.status = "INICIANDO"
        self.logs = deque(maxlen=4)
        self.prices = deque(maxlen=30)

        if clear_runtime:
            self.clear_runtime()

        self.root = tk.Tk()
        self.root.title("PredixAI Live")
        self.root.geometry("360x360+40+90")
        self.root.attributes("-topmost", True)
        self.root.resizable(False, False)
        self.root.protocol("WM_DELETE_WINDOW", self.close)

        self.vars = {
            "status": tk.StringVar(value="-"),
            "count": tk.StringVar(value="0/0"),
            "asset": tk.StringVar(value="-"),
            "price": tk.StringVar(value="-"),
            "balance": tk.StringVar(value="-"),
            "payout": tk.StringVar(value="-"),
            "timeframe": tk.StringVar(value="-"),
            "valid": tk.StringVar(value="-"),
            "reason": tk.StringVar(value="-"),
        }

        self.build_ui()

        if no_capture:
            self.status = "VISUALIZADOR"
        else:
            threading.Thread(target=self.run_capture, daemon=True).start()

        self.root.after(1000, self.refresh)

    def clear_runtime(self):
        runtime_dir().mkdir(parents=True, exist_ok=True)

        for name in [
            "last_live_reading.json",
            "live_price_history.json",
            "live_timing_profile.json",
        ]:
            path = runtime_dir() / name
            if path.exists():
                path.unlink()

    def build_ui(self):
        main = ttk.Frame(self.root, padding=10)
        main.pack(fill="both", expand=True)

        ttk.Label(main, text="PREDIXAI LIVE", font=("Arial", 14, "bold")).pack(anchor="w")

        for label, key in [
            ("Status", "status"),
            ("Leituras", "count"),
            ("Ativo", "asset"),
            ("Preço", "price"),
            ("Saldo", "balance"),
            ("Payout", "payout"),
            ("Tempo", "timeframe"),
            ("Válido", "valid"),
            ("Motivo", "reason"),
        ]:
            row = ttk.Frame(main)
            row.pack(fill="x", pady=1)
            ttk.Label(row, text=f"{label}:", width=8, font=("Arial", 9, "bold")).pack(side="left")
            ttk.Label(row, textvariable=self.vars[key], wraplength=250).pack(side="left")

        self.canvas = tk.Canvas(main, width=330, height=65, bg="white")
        self.canvas.pack(pady=8)

        self.log_label = ttk.Label(main, text="-", wraplength=330, font=("Arial", 8))
        self.log_label.pack(anchor="w")

        ttk.Label(
            main,
            text="Seguro: sem clique, sem compra, sem venda.",
            font=("Arial", 8, "italic"),
        ).pack(anchor="w", pady=(4, 0))

    def log(self, text):
        text = clean(text)
        if text:
            self.logs.append(text)
            self.log_label.config(text=" | ".join(self.logs))

    def run_capture(self):
        command = [
            sys.executable,
            "-m",
            "predixai.main",
            "--live-loop",
            "--loop-count",
            str(self.cycles),
            "--loop-interval",
            str(self.interval),
        ]

        self.status = "COLETANDO"
        self.log("live-loop iniciado")

        try:
            self.process = subprocess.Popen(
                command,
                cwd=str(project_root()),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

            code = self.process.wait()

            if code == 0:
                self.status = "FINALIZADO"
            else:
                self.status = f"ERRO {code}"

        except Exception as exc:
            self.status = "ERRO"
            self.log(str(exc))

    def read_state(self):
        title = get_broker_title()

        last = read_json(runtime_dir() / "last_live_reading.json", {})
        timing = latest_item(read_json(runtime_dir() / "live_timing_profile.json", []))
        history = read_json(runtime_dir() / "live_price_history.json", [])
        history_last = latest_item(history)

        asset = asset_from_title(title)
        title_price = price_from_title(title)

        price = title_price or pick(
            find_value(last, {"price"}),
            find_value(history_last, {"price", "price_value"}),
            find_value(timing, {"price"}),
        )

        price_value = to_float(price)

        if price_value is not None:
            self.prices.append(price_value)

        count = 0
        if isinstance(read_json(runtime_dir() / "live_timing_profile.json", []), list):
            count = len(read_json(runtime_dir() / "live_timing_profile.json", []))
        elif isinstance(history, list):
            count = len(history)

        return {
            "count": count,
            "asset": asset,
            "price": price,
            "balance": pick(
                find_value(last, {"balance"}),
                find_value(history_last, {"balance"}),
            ),
            "payout": pick(
                find_value(last, {"payout"}),
                find_value(history_last, {"payout"}),
                find_value(timing, {"payout"}),
            ),
            "timeframe": pick(
                find_value(last, {"timeframe"}),
                find_value(history_last, {"timeframe"}),
                find_value(timing, {"timeframe"}),
            ),
            "valid": find_value(timing, {"valid_runtime_reading"}),
            "reason": find_value(timing, {"rejection_reasons"}),
        }

    def refresh(self):
        state = self.read_state()

        reason = state["reason"]
        if isinstance(reason, list):
            reason = ", ".join(str(item) for item in reason)

        self.vars["status"].set(self.status)
        self.vars["count"].set(f"{state['count']}/{self.cycles}")
        self.vars["asset"].set(clean(state["asset"]) or "-")
        self.vars["price"].set(clean(state["price"]) or "-")
        self.vars["balance"].set(clean(state["balance"]) or "-")
        self.vars["payout"].set(clean(state["payout"]) or "-")
        self.vars["timeframe"].set(clean(state["timeframe"]) or "-")
        self.vars["valid"].set(clean(state["valid"]) or "-")
        self.vars["reason"].set(clean(reason) or "-")

        self.draw_chart()
        self.root.after(1500, self.refresh)

    def draw_chart(self):
        self.canvas.delete("all")
        prices = list(self.prices)

        if len(prices) < 2:
            self.canvas.create_text(165, 32, text="Aguardando preço...")
            return

        low = min(prices)
        high = max(prices)

        if high == low:
            high += 1

        points = []
        width = 330
        height = 65
        padding = 6

        for index, price in enumerate(prices):
            x = padding + (index / (len(prices) - 1)) * (width - 2 * padding)
            y = height - padding - ((price - low) / (high - low)) * (height - 2 * padding)
            points.extend([x, y])

        self.canvas.create_line(points, width=2)
        self.canvas.create_text(6, 6, anchor="nw", text=f"{low:.2f}/{high:.2f}")

    def close(self):
        try:
            if self.process and self.process.poll() is None:
                self.process.terminate()
        except Exception:
            pass

        self.root.destroy()

    def run(self):
        self.root.mainloop()


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--cycles", type=int, default=20)
    parser.add_argument("--interval", type=int, default=8)
    parser.add_argument("--clear-runtime", action="store_true")
    parser.add_argument("--no-capture", action="store_true")
    args = parser.parse_args()

    Popup(
        cycles=args.cycles,
        interval=args.interval,
        clear_runtime=args.clear_runtime,
        no_capture=args.no_capture,
    ).run()


if __name__ == "__main__":
    main()
