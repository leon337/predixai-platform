* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #0f172a;
  color: #e5e7eb;
  font-family: Arial, Helvetica, sans-serif;
}

.page {
  width: min(1240px, calc(100% - 32px));
  margin: 0 auto;
  padding: 32px 0 48px;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 24px;
}

.eyebrow {
  margin: 0 0 6px;
  color: #38bdf8;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

h1,
h2 {
  margin: 0;
}

h1 {
  font-size: clamp(32px, 5vw, 56px);
}

h2 {
  font-size: 28px;
}

.subtitle {
  margin: 8px 0 0;
  color: #94a3b8;
  font-size: 16px;
}

.status-card,
.card,
.panel,
.session-grid article,
.stats-grid article {
  background: rgba(15, 23, 42, 0.88);
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 18px;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.20);
}

.status-card {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 260px;
  padding: 16px;
}

.status-card strong,
.status-card small {
  display: block;
}

.status-card small {
  color: #94a3b8;
  margin-top: 4px;
}

.status-dot {
  width: 14px;
  height: 14px;
  border-radius: 999px;
  background: #22c55e;
  box-shadow: 0 0 18px rgba(34, 197, 94, 0.75);
}

.cards,
.stats-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
  margin-bottom: 18px;
}

.card,
.session-grid article,
.stats-grid article {
  padding: 18px;
}

.card span,
.session-grid span,
.stats-grid span {
  display: block;
  color: #94a3b8;
  font-size: 13px;
  margin-bottom: 8px;
}

.card strong,
.session-grid strong,
.stats-grid strong {
  display: block;
  font-size: 22px;
  line-height: 1.2;
}

.panel {
  padding: 22px;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.pill {
  border: 1px solid rgba(56, 189, 248, 0.35);
  background: rgba(56, 189, 248, 0.12);
  color: #bae6fd;
  border-radius: 999px;
  padding: 10px 14px;
  font-weight: 700;
}

.session-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 14px;
  margin-bottom: 18px;
}

.chart-wrap {
  width: 100%;
  overflow-x: auto;
  background: rgba(2, 6, 23, 0.52);
  border: 1px solid rgba(148, 163, 184, 0.16);
  border-radius: 18px;
  padding: 14px;
  margin-bottom: 18px;
}

#price_chart {
  width: 100%;
  min-width: 900px;
  height: auto;
  display: block;
}

@media (max-width: 1100px) {
  .cards,
  .session-grid,
  .stats-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .hero {
    align-items: flex-start;
    flex-direction: column;
  }
}

@media (max-width: 720px) {
  .cards,
  .session-grid,
  .stats-grid {
    grid-template-columns: 1fr;
  }

  .status-card {
    width: 100%;
  }
}
